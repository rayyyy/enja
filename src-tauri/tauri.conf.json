{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Enja",
  "version": "0.1.0",
  "identifier": "com.aimhack.enja",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Enja",
        "width": 1200,
        "height": 640,
        "minWidth": 640,
        "minHeight": 400,
        "center": true,
        "maximizable": false,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent",
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#fafafa",
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": true,
        "dragDropEnabled": false
      },
      {
        "label": "voice",
        "title": "Enja Voice",
        "width": 292,
        "height": 42,
        "minWidth": 260,
        "minHeight": 40,
        "center": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCONFIG/notes/images/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["bin/enja-speech-helper"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.4",
      "entitlements": "Entitlements.plist"
    }
  }
}
